// =============================================================================
// Volqan Framework — Prisma Schema
// =============================================================================
// Supports: PostgreSQL (default), MySQL, SQLite
// Datasource uses env("DATABASE_URL") for flexibility across environments.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// User roles that govern RBAC permissions across the system
enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

/// OAuth / credential provider identifiers
enum AuthProvider {
  google
  github
  credentials
}

/// Lifecycle status for content entries
enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Where uploaded media files are persisted
enum StorageProvider {
  LOCAL
  S3
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

/// Core user account. Stores identity, hashed credentials, and role.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  /// bcrypt-hashed password; null for pure OAuth users
  password      String?
  name          String?
  avatar        String?
  role          UserRole  @default(VIEWER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  contentEntries ContentEntry[]
  media         Media[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Account (OAuth)
// ---------------------------------------------------------------------------

/// Linked OAuth account for a user. One user can have multiple OAuth accounts.
model Account {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  /// OAuth access token (encrypted at application layer)
  accessToken       String?
  /// OAuth refresh token (encrypted at application layer)
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ---------------------------------------------------------------------------
// Session
// ---------------------------------------------------------------------------

/// Persistent sessions created on login. Supports multiple concurrent sessions.
model Session {
  id         String   @id @default(cuid())
  userId     String
  /// Opaque session token stored in a secure httpOnly cookie
  token      String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// ContentType (dynamic schema model)
// ---------------------------------------------------------------------------

/// Defines a dynamic content type (like a CMS collection). Fields and settings
/// are stored as JSON, allowing runtime schema definition without migrations.
model ContentType {
  id          String   @id @default(cuid())
  name        String
  /// URL-safe slug used to identify the content type in routes and APIs
  slug        String   @unique
  description String?
  /// Field definitions: array of { name, type, required, ... }
  fields      Json     @default("[]")
  /// Settings for display, API access, ordering, etc.
  settings    Json     @default("{}")
  /// System content types are protected and cannot be deleted by users
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries ContentEntry[]

  @@index([slug])
  @@index([isSystem])
  @@map("content_types")
}

// ---------------------------------------------------------------------------
// ContentEntry
// ---------------------------------------------------------------------------

/// A single entry of a content type. Data is stored as JSON for flexibility.
model ContentEntry {
  id            String        @id @default(cuid())
  contentTypeId String
  /// The actual field values as a JSON object
  data          Json          @default("{}")
  status        ContentStatus @default(DRAFT)
  /// URL slug for this entry (unique per content type)
  slug          String?
  authorId      String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contentType ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([contentTypeId, slug])
  @@index([contentTypeId])
  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
  @@map("content_entries")
}

// ---------------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------------

/// Uploaded media assets. Supports local filesystem and S3-compatible storage.
model Media {
  id              String          @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  /// File size in bytes
  size            Int
  url             String
  alt             String?
  folder          String?
  storageProvider StorageProvider @default(LOCAL)
  uploadedById    String?
  createdAt       DateTime        @default(now())

  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([folder])
  @@index([mimeType])
  @@map("media")
}

// ---------------------------------------------------------------------------
// Extension
// ---------------------------------------------------------------------------

/// Installed extension registry. Tracks enabled state and persisted settings.
model Extension {
  id          String   @id @default(cuid())
  /// Namespaced identifier in "vendor/name" format, e.g. "volqan/blog"
  extensionId String   @unique
  name        String
  version     String
  enabled     Boolean  @default(false)
  /// Extension-specific configuration stored as JSON
  settings    Json     @default("{}")
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@map("extensions")
}

// ---------------------------------------------------------------------------
// Theme
// ---------------------------------------------------------------------------

/// Installed theme registry. Only one theme may be active at a time.
model Theme {
  id          String   @id @default(cuid())
  /// Namespaced identifier, e.g. "volqan/default"
  themeId     String   @unique
  name        String
  version     String
  active      Boolean  @default(false)
  /// CSS design tokens and theme variables as JSON
  tokens      Json     @default("{}")
  installedAt DateTime @default(now())

  @@index([active])
  @@map("themes")
}

// ---------------------------------------------------------------------------
// Setting
// ---------------------------------------------------------------------------

/// Key-value store for application settings. Supports grouping and public flag.
model Setting {
  id        String   @id @default(cuid())
  /// Dot-notation key, e.g. "site.name" or "email.smtp.host"
  key       String   @unique
  /// Value stored as JSON to support any primitive or object
  value     Json
  /// Logical grouping for settings UI
  group     String   @default("general")
  /// Whether this setting can be read by unauthenticated requests
  isPublic  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([isPublic])
  @@map("settings")
}

// ---------------------------------------------------------------------------
// ApiKey
// ---------------------------------------------------------------------------

/// API keys for programmatic access. Key stored as bcrypt hash.
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  /// bcrypt hash of the actual key; the plain key is shown only once on creation
  key         String    @unique
  /// Array of allowed permission scopes, e.g. ["content:read", "media:write"]
  permissions Json      @default("[]")
  userId      String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// AuditLog
// ---------------------------------------------------------------------------

/// Immutable append-only log of privileged actions for compliance and debugging.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  /// Action performed, e.g. "user.created", "content.published"
  action     String
  /// Resource type affected, e.g. "User", "ContentEntry"
  resource   String
  /// ID of the affected resource
  resourceId String?
  /// Additional context (before/after snapshots, metadata)
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Installation
// ---------------------------------------------------------------------------

/// Tracks the Volqan installation identity, license, and plan.
/// Only one record should exist per deployment.
model Installation {
  id             String   @id @default(cuid())
  /// Stable UUID generated at first boot
  installationId String   @unique @default(uuid())
  licenseKey     String?
  plan           String   @default("community")
  domain         String?
  createdAt      DateTime @default(now())

  @@map("installations")
}
